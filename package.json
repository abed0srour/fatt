{
  "name": "ffat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c magenta,cyan \"next dev\" \"tsx watch --tsconfig tsconfig.server.json server/main.ts\"",
    "dev:web": "next dev",
    "api:dev": "tsx watch --tsconfig tsconfig.server.json server/main.ts",
    "api:build": "prisma generate && tsc -p tsconfig.server.json",
    "api:start": "node dist/server/main.js",
    "build:all": "npm run api:build && npm run build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@next/env": "^16.2.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.110.7",
    "lucide-react": "latest",
    "next": "16.2.1",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0"
  }
}
